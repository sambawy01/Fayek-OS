# ---------------------------------------------------------------------------
# Fayek OS — environment variables
# Copy to .env.local for local dev, and set the same keys in your Vercel project.
# Every integration fails CLOSED: if its vars are unset, that feature is simply
# disabled (401 / 501 / no-op) rather than crashing. So you can start with just
# the ADMIN_* + BLOB token and add the rest later.
# ---------------------------------------------------------------------------

# --- Admin auth (REQUIRED) --------------------------------------------------
# HTTP Basic Auth for /admin and every /api/admin/* route. With none of these
# set, nothing authenticates and the whole admin is locked.
ADMIN_USER=owner
ADMIN_PASS=change-me-to-a-long-random-string
# Optional legacy static key: allows /admin?key=<token> and the x-admin-key
# header. Leave unset unless you need shareable admin links.
ADMIN_TOKEN=

# --- Data store: Vercel Blob (REQUIRED) -------------------------------------
# Orders, catalog, CRM, finance ledger and backups all live in a private Vercel
# Blob store. Create a Blob store in the Vercel dashboard and paste its token.
BLOB_READ_WRITE_TOKEN=
# Token for uploaded media (product photos / receipts). Can be the same store.
MEDIA_READ_WRITE_TOKEN=

# --- Cron jobs (needed for scheduled reports) -------------------------------
# Vercel calls cron routes with "Authorization: Bearer ${CRON_SECRET}".
# The routes fail closed (401) when this is unset. Generate: openssl rand -hex 32
CRON_SECRET=

# --- Telegram owner bot "Fayek" (optional) ----------------------------------
# Create a bot with @BotFather (/newbot). Without a token the webhook route
# answers 501 and the daily-brief Telegram push no-ops.
TELEGRAM_BOT_TOKEN=
# Secret Telegram echoes back in the X-Telegram-Bot-Api-Secret-Token header on
# every update; the route fails closed without a match. openssl rand -hex 32
# then run: node scripts/setup-telegram.mjs
TELEGRAM_WEBHOOK_SECRET=

# --- Email: Resend (optional) -----------------------------------------------
# Outbound branded emails. When RESEND_API_KEY is unset, emails are logged and
# no-op'd.
RESEND_API_KEY=
# Where order/ops notifications are sent.
NOTIFY_EMAIL=owner@fayek-os.example.com
# Inbound customer-email triage (Resend Inbound -> /api/email/inbound). Put the
# Svix signing secret ("whsec_...") here; without it the route answers 501.
RESEND_WEBHOOK_SECRET=

# --- AI assistant: Ollama Cloud (optional) ----------------------------------
# Powers the Telegram assistant's reasoning + vision. Leave OLLAMA_API_KEY empty
# in local dev to use a local ollama at http://localhost:11434.
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_MODEL_HEAVY=gpt-oss:120b
OLLAMA_MODEL_VISION=gemini-3-flash-preview
# Enable the assistant's web_search / web_fetch tools ("true" to turn on).
WEB_SEARCH_ENABLED=

# --- Voice transcription: Groq Whisper (optional) ---------------------------
# Transcribes Telegram voice notes. Without it, voice notes are ignored.
GROQ_API_KEY=
